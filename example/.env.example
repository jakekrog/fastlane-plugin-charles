# Template for the per-developer, per-developer-secret values this plugin
# reads from the environment (see the Options table in README.md). Copy this
# to fastlane/.env (or wherever your project's fastlane looks for it) and
# fill in your own values — .env should never be committed.

# Path to the Charles application executable. Optional — defaults to
# /Applications/Charles.app/Contents/MacOS/Charles.
# FL_CHARLES_APP_PATH="/Applications/Charles.app/Contents/MacOS/Charles"

# Path to your simplified Charles YAML config. Optional — defaults to
# charles.yml. See example/charles.yml for the schema.
FL_CHARLES_CONFIG_PATH="example/charles.yml"

# Your Charles Proxy license. Both must be set together, or neither.
FL_CHARLES_REGISTERED_NAME="Your Name"
FL_CHARLES_REGISTERED_KEY="your-charles-license-key"

# IP ranges permitted to access the proxy that are specific to you (e.g.
# your own machine) rather than shared team config. Comma-separated for
# multiple. Each entry can be full CIDR notation ("10.0.0.0/8") or a bare IP
# ("10.0.1.20"), which is treated as /32 (that single host). Shared ranges
# belong in charles.yml's access_control.ip_ranges instead — see docs there
# for the split.
FL_CHARLES_IP_RANGES="10.0.1.20"

# Enable Charles debug-level logging for this session. Optional — defaults
# to false. Uncomment to pass Charles's --debug flag when launching the proxy.
# FL_CHARLES_DEBUG=true

# Charles application data directory for this session. Optional — when
# omitted, Charles uses its default location. Uncomment to isolate a lane or
# CI run from your interactive Charles profile (SSL store, profiles, etc.).
# FL_CHARLES_DATA_PATH="/tmp/charles-data"

# Launch Charles without a UI. Optional — defaults to false. Uncomment for
# unattended lanes or CI where Charles should run headless.
# FL_CHARLES_HEADLESS=true

# Activate throttling for this session. Optional — defaults to false.
# Uses throttle settings from Charles's config or data directory; defining
# throttle presets in charles.yml is not yet supported.
# FL_CHARLES_THROTTLING=true
